# Copy to .env and fill in values. Never commit real secrets.

# --- Core ---
NODE_ENV=development
PORT=3000
SESSION_SECRET=
SESSION_SECURE=false
LOG_LEVEL=info
# Set to json for structured logs (Datadog, CloudWatch, etc.)
# LOG_FORMAT=json

# --- Scale / cost control (discovery + Serper + Gemini) ---
# Max discovery API calls per user per window (default 15 min, 24 requests)
# DISCOVER_RATE_WINDOW_MS=900000
# DISCOVER_RATE_MAX=24
# Cap Serper HTTP calls inside one keyword discovery (search_query expansion)
# DISCOVER_MAX_SERPER_CALLS=8
# Cap Serper calls for POST /api/discover/google multi-query flow
# DISCOVER_GOOGLE_MAX_SERPER_CALLS=12
# SERPER_TIMEOUT_MS=20000
# SERPER_MAX_RETRIES=2
# GEMINI_MAX_RETRIES=3
# GEMINI_RETRY_BASE_MS=900

# --- Worker ---
# WORKER_CRON=0 * * * *
# WORKER_SHUTDOWN_GRACE_MS=120000
# WORKER_RUN_ON_START=false

# --- Health ---
# GET /health — liveness
# GET /health/ready — DB readiness (use for load balancer probes)
