# Copy this file to .env and fill in your values

# Google Gemini AI API Key (get from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Server Configuration
PORT=4000
SESSION_SECRET=change-this-to-random-string-in-production

# Admin Account (will be created on first run)
ADMIN_USER=admin
ADMIN_PASSWORD=change-this-password

# Email Notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
NOTIFY_TO=your-email@gmail.com
