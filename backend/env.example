# Copy to .env and fill in values. Never commit real secrets.

# --- Core ---
NODE_ENV=development
PORT=3000
SESSION_SECRET=
SESSION_SECURE=false
LOG_LEVEL=info
# Set to json for structured logs (Datadog, CloudWatch, etc.)
# LOG_FORMAT=json

# --- Scale / cost control (discovery + Serper + Gemini) ---
# Max discovery API calls per user per window (default 15 min, 24 requests)
# DISCOVER_RATE_WINDOW_MS=900000
# DISCOVER_RATE_MAX=24
# Cap Serper HTTP calls inside one keyword discovery (search_query expansion)
# DISCOVER_MAX_SERPER_CALLS=8
# Cap Serper calls for POST /api/discover/google multi-query flow
# DISCOVER_GOOGLE_MAX_SERPER_CALLS=12
# SERPER_TIMEOUT_MS=20000
# SERPER_MAX_RETRIES=2
# GEMINI_MAX_RETRIES=3
# GEMINI_RETRY_BASE_MS=900

# --- Signal line (seller one-liner: "[Address] - Event") ---
# When ICP fields are empty, still generate signal_line via Gemini (extra API call per lead)
# SIGNAL_LINE_WITHOUT_ICP_PROFILE=true

# --- Worker ---
# WORKER_CRON=0 * * * *
# WORKER_SHUTDOWN_GRACE_MS=120000
# WORKER_RUN_ON_START=false

# --- Health ---
# GET /health — liveness
# GET /health/ready — DB readiness (use for load balancer probes)

# --- Subscription tiers (see config/plans.js) ---
# billing_accounts.plan_key: free | starter | growth | scale
# Optional Paddle price IDs for checkout:
# PADDLE_PRICE_STARTER=
# PADDLE_PRICE_GROWTH=
# PADDLE_PRICE_SCALE=

# --- API surface ---
# GET /api/usage — monthly usage vs limits (session)
# GET /api/billing/status — billing + usage
# POST /api/sources/connectors — add JSON API source (Bearer-style headers in body)
# POST /api/ingest/leads — inbound leads (Authorization: Bearer <ingest token>)
# GET/POST/DELETE /api/ingest/tokens — manage tokens (session, paid)
# Dev only: bypass paid checks for sources, scrape, discovery, ingest tokens (never in production)
# ALLOW_UNPAID_SCRAPE=true

# --- Security / CORS ---
# Comma-separated browser origins (e.g. https://app.example.com,http://localhost:3000).
# Empty = reflect CORS as allow-all (credentials off when using *).
# CORS_ORIGINS=
# Stricter list for API_ORIGIN_ENFORCE (defaults to CORS_ORIGINS if unset)
# TRUSTED_ORIGINS=
# API_ORIGIN_ENFORCE=false
# Optional public URL for security.txt Policy line and links
# APP_URL=http://localhost:3000
# PUBLIC_URL=
# SECURITY_CONTACT_EMAIL=
# SECURITY_POLICY_URL=/terms.html

# --- Redis (optional) — distributed rate limits when set ---
# REDIS_URL=

# --- Observability ---
# Bearer token required for GET /metrics in production; omit in dev for open /metrics
# METRICS_BEARER_TOKEN=

# --- AI Enrichment page (optional) ---
# Street View static image on /api/enrichment/map-preview; if unset, OSM satellite-style static map is used
# GOOGLE_MAPS_API_KEY=
