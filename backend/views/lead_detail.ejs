<section class="space-y-4">
  <a href="/app/leads" class="inline-flex items-center gap-2 text-slate-300 underline">← Back to list</a>
  <div class="grid md:grid-cols-3 gap-4">
    <div class="md:col-span-2 space-y-4">
      <div class="rounded-xl border border-slate-800 bg-slate-900/40 p-5">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h1 class="text-xl font-semibold">Lead Detail</h1>
            <p class="text-sm text-slate-400"><%= lead.source %> · <%= lead.date_added %></p>
          </div>
          <div class="flex items-center gap-2">
            <% if (lead.address) { %>
              <button type="button" class="px-3 py-1.5 rounded bg-slate-800 hover:bg-slate-700" onclick="copyText('<%- (lead.address||'').replace(/'/g, "\\'") %>')">Copy address</button>
              <a target="_blank" class="px-3 py-1.5 rounded bg-emerald-600 hover:bg-emerald-500 text-white" href="https://www.google.com/maps/search/?api=1&query=<%= encodeURIComponent(lead.address) %>">Open map</a>
            <% } %>
          </div>
        </div>
        <div class="mt-4 grid sm:grid-cols-2 gap-4">
          <div>
            <div class="text-xs text-slate-400">Permit #</div>
            <div class="font-semibold"><%= lead.permit_number || 'N/A' %></div>
          </div>
          <div>
            <div class="text-xs text-slate-400">Value</div>
            <div class="text-emerald-400 font-semibold"><%= lead.value || 'N/A' %></div>
          </div>
          <div class="sm:col-span-2">
            <div class="text-xs text-slate-400">Address</div>
            <div class="text-slate-200"><%= lead.address || '' %></div>
          </div>
          <div class="sm:col-span-2">
            <div class="text-xs text-slate-400">Description</div>
            <div class="text-slate-200 whitespace-pre-wrap"><%= lead.description || '' %></div>
          </div>
        </div>
      </div>
      <div class="rounded-xl border border-slate-800 bg-slate-900/40">
        <div class="p-3 border-b border-slate-800 font-semibold">Raw</div>
        <pre class="p-4 overflow-auto text-xs leading-relaxed"><%= (lead.raw_text || '') %></pre>
      </div>
    </div>
    <aside class="space-y-4">
      <div class="rounded-xl border border-slate-800 bg-slate-900/40 p-4">
        <div class="text-sm text-slate-400">Hash</div>
        <div class="text-xs break-all"><%= lead.hash %></div>
      </div>
    </aside>
  </div>
</section>
