[
  {
    "name": "Nashville Multifamily Permits",
    "url": "https://data.nashville.gov/resource/b3pt-j96x.json",
    "method": "json",
    "requestMethod": "GET",
    "params": {
      "$where": "permit_type_description='Building Residential - New' AND date_issued >= '2024-01-01T00:00:00'",
      "$order": "date_issued DESC",
      "$limit": 500
    },
    "jsonFields": [
      "permit_number",
      "address",
      "const_cost",
      "work_description",
      "contractor_name",
      "contractor_phone",
      "date_issued"
    ],
    "useAI": false,
    "enabled": true,
    "notes": "Nashville TN - Multifamily residential new construction permits via Socrata API"
  },
  {
    "name": "Phoenix Building Permits",
    "url": "https://apps-secure.phoenix.gov/PDD/Search/IssuedPermit",
    "method": "puppeteer",
    "puppeteerConfig": {
      "waitForSelector": "select[name='ddlStructureClass']",
      "actions": [
        {
          "type": "select",
          "selector": "select[name='ddlPermitType']",
          "value": "-ALL-"
        },
        {
          "type": "select",
          "selector": "select[name='ddlStructureClass']",
          "value": "007"
        },
        {
          "type": "fill",
          "selector": "input[name='txtStartDate']",
          "value": "01/01/2024"
        },
        {
          "type": "click",
          "selector": "input[name='btnSearch']"
        },
        {
          "type": "wait",
          "duration": 8000
        }
      ],
      "dataSelector": ".k-grid tbody tr, table.k-grid-table tbody tr"
    },
    "useAI": true,
    "enabled": true,
    "notes": "Phoenix AZ - Multifamily 10+ units (code 007). Uses ddlStructureClass='007' and btnSearch button."
  },
  {
    "name": "Scottsdale Building Permits",
    "url": "https://eservices.scottsdaleaz.gov/bldgresources/BuildingPermit/reports",
    "method": "puppeteer",
    "puppeteerConfig": {
      "waitForSelector": "form",
      "actions": [
        {
          "type": "fill",
          "selector": "input[name='OccupancyType'], select[name='OccupancyType']",
          "value": "Multifamily"
        },
        {
          "type": "click",
          "selector": "button[type='submit'], input[type='submit'], button.submit"
        },
        {
          "type": "wait",
          "duration": 5000
        }
      ],
      "dataSelector": "table tbody tr, .results tr"
    },
    "useAI": true,
    "enabled": true,
    "notes": "Scottsdale AZ - Form-based permit search system"
  },
  {
    "name": "Mesa Building Permits",
    "url": "https://data.mesaaz.gov/resource/2gkz-7z4f.json",
    "method": "json",
    "requestMethod": "GET",
    "params": {
      "$where": "issued_date >= '2024-01-01T00:00:00'",
      "$order": "issued_date DESC",
      "$limit": 500
    },
    "jsonFields": [
      "permit_number",
      "property_address",
      "value",
      "description",
      "applicant",
      "issued_date",
      "type_of_work"
    ],
    "useAI": false,
    "enabled": true,
    "notes": "Mesa AZ - Socrata Open Data API (correct field names: property_address, value)"
  },
  {
    "name": "Miami-Dade Building Permits",
    "url": "https://gis.mdc.opendata.arcgis.com/datasets/MDC::building-permits-issued-by-miami-dade-county-2-previous-years-to-present.geojson",
    "method": "json",
    "requestMethod": "GET",
    "jsonPath": "features",
    "jsonFields": [
      "properties.FolioNumber",
      "properties.SiteAddress",
      "properties.EstimatedCost",
      "properties.ProposedUseDescription",
      "properties.ContractorName",
      "properties.ContractorPhone",
      "properties.ApplicationDate"
    ],
    "useAI": false,
    "enabled": true,
    "notes": "Miami-Dade FL - GeoJSON format from ArcGIS Open Data"
  },
  {
    "name": "Fort Lauderdale Construction",
    "url": "https://aca-prod.accela.com/FTL/Cap/GlobalSearchResults.aspx?isNewQuery=yes&QueryText=new%20construction%20Multi",
    "method": "puppeteer",
    "puppeteerConfig": {
      "waitForSelector": "table.grid, table[id*='result'], .search-results",
      "actions": [
        {
          "type": "wait",
          "duration": 5000
        }
      ],
      "dataSelector": "table.grid tbody tr, table[id*='result'] tbody tr, .search-results tr"
    },
    "useAI": true,
    "enabled": true,
    "notes": "Fort Lauderdale FL - Accela system for multifamily construction"
  },
  {
    "name": "Tampa Construction Inspections",
    "url": "https://gis.tampagov.net/arcgis/rest/services/AppsPublic/TampaBuilding/MapServer/0/query",
    "method": "json",
    "requestMethod": "GET",
    "params": {
      "where": "1=1",
      "outFields": "*",
      "f": "json",
      "resultRecordCount": 500,
      "orderByFields": "OBJECTID DESC"
    },
    "jsonPath": "features",
    "jsonFields": [
      "attributes.PERMIT",
      "attributes.ADDRESS",
      "attributes.TOTAL_VALUE",
      "attributes.DESCRIPTION",
      "attributes.CONTRACTOR",
      "attributes.DATE"
    ],
    "useAI": false,
    "enabled": true,
    "notes": "Tampa FL - Correct ArcGIS MapServer endpoint"
  }
]
