# Shiiman Leads - Example Environment Variables (do not commit real secrets)

# Core
NODE_ENV=production
SESSION_SECRET=change-me-please-strong-random

# Database (set to your mounted volume paths in production)
SQLITE_DB_PATH=/app/backend/SQLITE_DB_PATH/leads.db
SQLITE_SESSIONS_DB_PATH=/app/backend/SQLITE_DB_PATH/sessions.db

# Sessions (override cookie flags as needed)
SESSION_SECURE=false
SESSION_SAMESITE=lax

# SMTP (optional)
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=example@outlook.com
SMTP_PASS=example-password
NOTIFY_TO=notify@example.com

# Google Gemini (optional)
GEMINI_API_KEY=example-gemini-key
SHIIMAN_USER_AGENT=EXAMPLE-USER-AGENT

# Playwright (optional)
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_CHROMIUM_ARGS=--no-sandbox

# Outbox (optional)
OUTBOX_JSONL_PATH=/app/backend/output/latest_leads.jsonl

# Auto-scrape cron (quote the expression)
AUTO_SCRAPE_INTERVAL="0 */8 * * *"
