<section class="min-h-[70vh] grid place-items-center">
  <div class="w-full max-w-md bg-slate-900/50 border border-slate-800 rounded-xl p-6 shadow-xl shadow-black/20">
    <div class="flex items-center gap-3 mb-5">
      <span class="inline-grid place-items-center h-9 w-9 rounded-full bg-emerald-600/10 text-emerald-400 border border-emerald-500/30">A</span>
      <div>
        <h1 class="text-xl font-semibold leading-tight">Sign in</h1>
        <p class="text-sm text-slate-400">Access your construction leads</p>
      </div>
    </div>
    <% if (error) { %>
      <div class="mb-4 bg-red-900/40 border border-red-800 text-red-200 rounded px-3 py-2"><%= error %></div>
    <% } %>
    <form method="post" action="/login" class="space-y-4">
      <div>
        <label class="block text-xs text-slate-400 mb-1">Username</label>
        <input name="username" class="w-full bg-slate-800/70 border border-slate-700 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-600" required />
      </div>
      <div>
        <label class="block text-xs text-slate-400 mb-1">Password</label>
        <input type="password" name="password" class="w-full bg-slate-800/70 border border-slate-700 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-600" required />
      </div>
      <button class="w-full px-3 py-2 rounded bg-emerald-600 hover:bg-emerald-500">Sign in</button>
    </form>
  </div>
  <p class="mt-6 text-center text-xs text-slate-500">© <%= new Date().getFullYear() %> Aurora Leads</p>
</section>
