<section class="space-y-4">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight">Leads</h1>
      <p class="text-sm text-slate-400">Latest construction permits and project data</p>
    </div>
    <div class="flex items-center gap-2">
      <form class="flex flex-wrap items-end gap-2" method="get" action="/app/leads">
      <div>
        <label class="block text-xs text-slate-400">Search</label>
        <input name="q" value="<%= q || '' %>" class="bg-slate-900/60 border border-slate-700 rounded px-3 py-2" placeholder="permit, address, text" />
      </div>
      <div>
        <label class="block text-xs text-slate-400">Source</label>
        <select name="source" class="bg-slate-900/60 border border-slate-700 rounded px-3 py-2">
          <option value="">All</option>
          <% (sources || []).forEach(s => { %>
            <option value="<%= s %>" <%= s === source ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="block text-xs text-slate-400">Days</label>
        <input name="days" type="number" min="0" value="<%= days || '' %>" class="w-28 bg-slate-900/60 border border-slate-700 rounded px-3 py-2" />
      </div>
      <div>
        <label class="block text-xs text-slate-400">Page size</label>
        <input name="pageSize" type="number" min="5" max="100" value="<%= pageSize %>" class="w-28 bg-slate-900/60 border border-slate-700 rounded px-3 py-2" />
      </div>
      <button class="px-3 py-2 rounded bg-emerald-600 hover:bg-emerald-500">Apply</button>
      </form>
      <% const qStr = new URLSearchParams({ q: q||'', source: source||'', days: days||'', pageSize: pageSize }).toString(); %>
      <a class="px-3 py-2 rounded bg-slate-800 hover:bg-slate-700" href="/app/leads.csv?<%= qStr %>">Export CSV</a>
      <form method="post" action="/app/scrape-now">
        <button class="px-3 py-2 rounded bg-slate-800 hover:bg-slate-700" type="submit" onclick="showToast('Scrape started')">Scrape Now</button>
      </form>
    </div>
  </div>

  <% if (!rows || rows.length === 0) { %>
    <div class="rounded-xl border border-slate-800 bg-slate-900/40 p-8 text-center">
      <h3 class="font-semibold mb-1">No results</h3>
      <p class="text-sm text-slate-400">Try removing filters or expanding the date range.</p>
    </div>
  <% } else { %>
    <div class="overflow-x-auto rounded-xl border border-slate-800">
      <table class="min-w-full table-fixed">
        <thead class="bg-slate-900/80 text-slate-400 text-xs uppercase sticky top-0 z-10">
          <tr>
            <th class="text-left p-3 w-36">Date</th>
            <th class="text-left p-3 w-40">Source</th>
            <th class="text-left p-3 w-44">Permit</th>
            <th class="text-left p-3">Address</th>
            <th class="text-left p-3 w-36">Value</th>
            <th class="text-left p-3 w-28">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach(r => { %>
            <tr class="border-t border-slate-800 hover:bg-slate-900/50">
              <td class="p-3 text-sm text-slate-300"><%= r.date_added %></td>
              <td class="p-3 text-sm"><span class="px-2 py-1 rounded border border-slate-700 text-slate-300"><%= r.source %></span></td>
              <td class="p-3 font-semibold truncate"><%= r.permit_number || 'N/A' %></td>
              <td class="p-3 text-slate-300 truncate" title="<%= r.address || '' %>"><%= r.address || '' %></td>
              <td class="p-3 text-emerald-400 font-semibold"><%= r.value || 'N/A' %></td>
              <td class="p-3 text-sm flex items-center gap-2">
                <a class="underline" href="/app/leads/<%= r.id %>">View</a>
                <% if (r.address) { %>
                  <button type="button" class="text-slate-300 underline" data-address="<%= (r.address||'').replace(/"/g,'&quot;') %>" onclick="copyText(this.dataset.address)">Copy</button>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="mt-4 flex items-center justify-between">
      <div class="text-sm text-slate-400">Total: <%= total %> · Page <%= page %>/<%= pages %></div>
      <nav class="flex items-center gap-1">
        <% const qStr = new URLSearchParams({ q: q||'', source: source||'', days: days||'', pageSize: pageSize }).toString(); %>
        <% const MAX_PAGES = 7; const start = Math.max(1, page - 3); const end = Math.min(pages, start + MAX_PAGES - 1); %>
        <% if (page > 1) { %>
          <a class="px-3 py-1 rounded bg-slate-800 hover:bg-slate-700" href="/app/leads?page=1&<%= qStr %>">First</a>
          <a class="px-3 py-1 rounded bg-slate-800 hover:bg-slate-700" href="/app/leads?page=<%= page - 1 %>&<%= qStr %>">Prev</a>
        <% } %>
        <% for (let p = start; p <= end; p++) { %>
          <a class="px-3 py-1 rounded <%= p === page ? 'bg-emerald-600' : 'bg-slate-800 hover:bg-slate-700' %>" href="/app/leads?page=<%= p %>&<%= qStr %>"><%= p %></a>
        <% } %>
        <% if (page < pages) { %>
          <a class="px-3 py-1 rounded bg-slate-800 hover:bg-slate-700" href="/app/leads?page=<%= page + 1 %>&<%= qStr %>">Next</a>
          <a class="px-3 py-1 rounded bg-slate-800 hover:bg-slate-700" href="/app/leads?page=<%= pages %>&<%= qStr %>">Last</a>
        <% } %>
      </nav>
    </div>
  <% } %>
</section>
