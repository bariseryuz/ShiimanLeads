{
  "name": "shiiman-leads",
  "version": "1.0.0",
  "description": "Automated construction permit leads ",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "pm2-start": "pm2 start index.js --name shiiman-leads",
    "pm2-save": "pm2 save",
    "pm2-restart": "pm2 restart shiiman-leads",
    "pm2-stop": "pm2 stop shiiman-leads",
    "build": "node build.js",
    "api": "node server.js",
    "postinstall": "node -e \"try { require('better-sqlite3') } catch (e) { console.log('better-sqlite3 installed') }\" && npx playwright install chromium"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.5.0",
    "better-sqlite3-session-store": "^0.1.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.17.3",
    "groq-sdk": "^0.37.0",
    "jsonpath": "^1.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "papaparse": "^5.5.3",
    "playwright": "^1.49.0",
    "sharp": "^0.33.4",
    "sqlite3": "^5.1.7",
    "undici": "^7.19.1",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
